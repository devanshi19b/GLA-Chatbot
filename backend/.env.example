# Groq API key
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
HF_EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=2500
CHUNK_OVERLAP=150
TOP_K=4
CRAWL_ALLOWED_DOMAINS=gla.ac.in,www.gla.ac.in,glauniversity.in,www.glauniversity.in,student.glauniversity.in
OFFICIAL_SITE_URL=https://www.gla.ac.in/info/common/
# Optional: comma-separated extra official pages to seed during website sync.
OFFICIAL_SITE_SEED_URLS=
OFFICIAL_SITE_MAX_PAGES=12
# Optional: automatically sync official website data during chat requests.
OFFICIAL_SITE_AUTO_SYNC_ENABLED=true
# Cooldown for auto sync in seconds. Set to 0 to sync on every eligible request.
OFFICIAL_SITE_AUTO_SYNC_INTERVAL_SECONDS=600
# If true, auto sync only for website/official/latest style questions.
OFFICIAL_SITE_AUTO_SYNC_WEBSITE_ONLY=true
# Optional: comma-separated list of allowed frontend origins for CORS.
# Defaults already allow localhost and 127.0.0.1 on common dev ports.
CORS_ORIGINS=
